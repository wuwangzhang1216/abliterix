# ========================
# Abliterix project
# ========================

# User config (configs/default.toml is the tracked template)
/config.toml
/abliterix.toml

# Datasets (user-provided, not distributed with the project)
/datasets/

# Model cards (for HF uploads, not part of the project)
/configs/*_modelcard.md

# Study checkpoints (generated at runtime)
checkpoints*/

# Experiment outputs (generated at runtime)
experiments*/

# HonestAbliterationBench: track the spec, the contributing guide, the
# result JSONs that build the leaderboard, and the auto-generated
# leaderboard.json mirror. Ignore the large per-prompt raw outputs and
# any local scratch under benchmarks/.
/benchmarks/results/*.outputs.jsonl
/benchmarks/space/
/benchmarks/_scratch/

# One-off scratch scripts
/scratch/

# Residual analysis plots
/plots/

# Packaging artifacts
*.tar
*.tar.gz
*.zip

